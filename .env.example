# Environment
NODE_ENV=development
ENVIRONMENT=development
PORT=8000
PROJECT_NAME=Salon Booking

# Database (Heroku PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# JWT Configuration
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Eskiz SMS Service
ESKIZ_EMAIL=your-eskiz-email
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_BASE_URL=https://notify.eskiz.uz/api

# Click Payment Service
CLICK_SERVICE_ID=your-click-service-id
CLICK_SECRET_KEY=your-click-secret-key
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_MERCHANT_USER_ID=your-click-merchant-user-id
CLICK_API_URL=https://api.click.uz/v2/

# Frontend URL
FRONTEND_URL=https://freya-admin.vercel.app

# File Upload (ImgBB - Heroku uchun)
IMGBB_API_KEY=your-imgbb-api-key

# Telegram Bot Secret (bot API uchun)
BOT_SECRET_KEY=your-bot-secret-key

# DeepL Translation (optional)
DEEPL_API_KEY=your-deepl-api-key
